<?xml version="1.0" encoding="utf-8"?>
<extension type="plugin" group="content" method="upgrade">
	<name>PLG_CONTENT_SS</name>
	<author>SuperSaaS</author>
	<creationDate>April 2026</creationDate>
	<copyright>Copyright (C) 2026 SuperSaaS. All rights reserved.</copyright>
	<license>GNU General Public License version 3 or later; see LICENSE.txt</license>
	<authorEmail>info@supersaas.com</authorEmail>
	<authorUrl>www.supersaas.com</authorUrl>
	<version>3.0.0</version>
	<description>PLG_CONTENT_SS_DESCRIPTION</description>

	<namespace path="src">SuperSaaS\Plugin\Content\Supersaas</namespace>

	<files>
		<folder plugin="supersaas">services</folder>
		<folder>src</folder>
		<folder>language</folder>
	</files>

	<config>
		<fields name="params">
			<fieldset name="settings" label="SuperSaaS Plugin Settings">
				<field
					name="account_name"
					type="text"
					label="PLG_CONTENT_SS_ACCOUNT_NAME"
					description="PLG_CONTENT_SS_ACCOUNT_NAME_DESCRIPTION"
					required="true"
				/>
				<field
					name="password"
					type="text"
					label="PLG_CONTENT_SS_API_KEY"
					description="PLG_CONTENT_SS_API_KEY_DESCRIPTION"
					required="true"
				/>
				<field
					name="custom_domain"
					type="text"
					label="PLG_CONTENT_SS_CUSTOM_DOMAIN"
					description="PLG_CONTENT_SS_CUSTOM_DOMAIN_DESCRIPTION"
				/>
				<field
					name="schedule"
					type="text"
					label="PLG_CONTENT_SS_SCHEDULE"
					description="PLG_CONTENT_SS_SCHEDULE"
				/>
			</fieldset>
		</fields>
	</config>
</extension>
